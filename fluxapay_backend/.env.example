# Server Configuration
NODE_ENV=development
PORT=3000
BASE_URL=http://localhost:3000
PAY_CHECKOUT_BASE=http://localhost:3001
PAYMENT_RATE_LIMIT_PER_MINUTE=5
PAYMENT_METADATA_MAX_BYTES=16384
PAYMENT_METADATA_MAX_DEPTH=5
CORS_ORIGINS=http://localhost:3001,http://localhost:3000

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/fluxapay

# JWT
JWT_SECRET=your-secret-key-here

# Cloudinary (optional)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email (optional)
RESEND_API_KEY=

# SMS OTP (optional)
SMS_PROVIDER=none
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
MESSAGEBIRD_API_KEY=
MESSAGEBIRD_ORIGINATOR=
OTP_SMS_MAX_PER_MERCHANT_HOUR=10
OTP_SMS_COST_ALERT_DAILY_THRESHOLD=1000

# Webhook
WEBHOOK_SECRET=your-webhook-secret

# Stellar Configuration
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
STELLAR_BASE_FEE=100
STELLAR_MAX_FEE=2000
STELLAR_FEE_BUMP_MULTIPLIER=2
STELLAR_TX_MAX_RETRIES=3
FUNDER_SECRET_KEY=S...
USDC_ISSUER_PUBLIC_KEY=GBBD47IF6LWK7P7MDEVSCWT73IQIGCEZHR7OMXMBZQ3ZONN2T4U6W23Y
MASTER_VAULT_SECRET_KEY=S...
FUNDER_PUBLIC_KEY=G...
SWEEP_ENABLE_ACCOUNT_MERGE=false
SWEEP_CRON=*/5 * * * *
SWEEP_LOCK_TTL_MS=600000

# KMS Configuration
KMS_PROVIDER=local
KMS_ENCRYPTION_PASSPHRASE=your-encryption-passphrase
KMS_ENCRYPTED_MASTER_SEED=
HD_WALLET_MASTER_SEED=

# AWS KMS (if KMS_PROVIDER=aws)
AWS_KMS_KEY_ID=
AWS_REGION=us-east-1

# Soroban Smart Contracts (optional)
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
SOROBAN_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
MERCHANT_REGISTRY_CONTRACT_ID=
PAYMENT_CONTRACT_ID=
ADMIN_SECRET_KEY=

# Settlement Batch
EXCHANGE_PARTNER=mock
YELLOWCARD_API_KEY=
YELLOWCARD_API_URL=
ANCHOR_API_KEY=
ANCHOR_API_URL=
SETTLEMENT_FEE_PERCENT=2
SETTLEMENT_CRON=0 0 * * *
SETTLEMENT_BATCH_LIMIT=500

# Exchange Partner Feature Flags
ENABLE_YELLOWCARD_VALIDATION=false
ENABLE_ANCHOR_VALIDATION=false

# Payment Oracle Configuration
ORACLE_POLLING_INTERVAL_MS=30000
ORACLE_MAX_MISSED_POLLS=5
ORACLE_BATCH_SIZE=50
ORACLE_HORIZON_TIMEOUT_MS=10000
ENABLE_SOROBAN_VERIFICATION=false

# Cron Jobs
DISABLE_CRON=false
BILLING_CRON=0 1 * * *
FUNDER_MONITOR_CRON=*/10 * * * *
PAYMENT_EXPIRY_CRON=*/5 * * * *

# Shutdown
SHUTDOWN_TIMEOUT_MS=30000

# Logging
LOG_LEVEL=info
